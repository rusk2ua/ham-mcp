# AWS S3 data lake
# ARN format: arn:aws:s3:::ham-mcp-demo-bucket — use only the bucket name (last segment)
# Example: S3_BUCKET=ham-mcp-bucket
AWS_REGION=us-east-1
S3_BUCKET=

# Google Drive (public folder share ID, from the share URL)
# Example: https://drive.google.com/drive/folders/1pltTUZCm1mvyBPrUMGEcFs9szd3ErWwA?usp=sharing
#          GDRIVE_FOLDER_ID=1pltTUZCm1mvyBPrUMGEcFs9szd3ErWwA
GDRIVE_FOLDER_ID=

# Optional: named AWS profile (leave blank to use default credentials)
# AWS_PROFILE=
